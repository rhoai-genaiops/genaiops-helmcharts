{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Llama Stack Operator Instance Helm Chart Values Schema",
  "description": "Schema for validating values.yaml configuration for the Llama Stack Operator Instance Helm chart",
  "properties": {
    "models": {
      "type": "array",
      "description": "List of models to configure for inference",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the model (used as model_id and provider_id)",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "description": "URL endpoint for the model inference service",
            "pattern": "^https?://[^\\s]+$"
          },
          "token": {
            "type": "string",
            "description": "Optional API token for authenticating with the model inference service"
          }
        },
        "required": ["name", "url"],
        "additionalProperties": false
      },
      "default": [
        {
          "name": "llama32",
          "url": "http://llama-32-predictor.ai501.svc.cluster.local:8080/v1"
        }
      ],
      "examples": [
        [
          {
            "name": "llama32",
            "url": "http://llama-32-predictor.ai501.svc.cluster.local:8080/v1"
          }
        ],
        [
          {
            "name": "llama32",
            "url": "http://llama-32-predictor.ai501.svc.cluster.local:8080/v1"
          },
          {
            "name": "mistral-7b",
            "url": "http://mistral-predictor.ai501.svc.cluster.local:8080/v1"
          }
        ]
      ]
    },
    "distribution": {
      "type": "object",
      "description": "Distribution configuration for Llama Stack",
      "properties": {
        "image": {
          "type": "string",
          "description": "Container image for the Llama Stack distribution",
          "minLength": 1,
          "default": "quay.io/rhoai-genaiops/odh-llama-stack-core-rhel9:rhoai-3.4-shields",
          "examples": [
            "quay.io/rhoai-genaiops/odh-llama-stack-core-rhel9:rhoai-3.4-shields",
            "registry.example.com/llama-stack:latest"
          ]
        }
      },
      "required": ["image"],
      "additionalProperties": false
    },
    "configMap": {
      "type": "object",
      "description": "ConfigMap configuration settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable ConfigMap creation",
          "default": true
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "telemetry": {
      "type": "object",
      "description": "Telemetry configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable telemetry collection",
          "default": true
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "rag": {
      "type": "object",
      "description": "RAG (Retrieval-Augmented Generation) configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable RAG functionality",
          "default": false
        },
        "milvus": {
          "type": "object",
          "description": "Milvus vector database configuration",
          "properties": {
            "service": {
              "type": "string",
              "description": "Milvus service name",
              "minLength": 1,
              "default": "milvus-test",
              "examples": [
                "milvus-test",
                "milvus-prod"
              ]
            }
          },
          "required": ["service"],
          "additionalProperties": false
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "mcp": {
      "type": "object",
      "description": "Model Context Protocol configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable MCP functionality",
          "default": false
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "mcp_aihub": {
      "type": "object",
      "description": "MCP AI Hub integration configuration for deploying MCP servers to AI Hub",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable MCP AI Hub integration and server deployment",
          "default": false
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "otelCollector": {
      "type": "object",
      "description": "OpenTelemetry Collector configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable OpenTelemetry Collector integration",
          "default": true
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "guardrails": {
      "type": "object",
      "description": "NeMo Guardrails configuration — when enabled, registers the nvidia-local-nemo safety provider pointing at the canopy-guardrails service",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable NeMo Guardrails integration",
          "default": false
        }
      },
      "required": ["enabled"],
      "additionalProperties": false
    },
    "sealed_secrets": {
      "type": "object",
      "description": "Sealed Secrets configuration for encrypted secret management",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable or disable Sealed Secrets integration",
          "default": false
        },
        "secretName": {
          "type": "string",
          "description": "Name of the sealed secret to use",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "models",
    "distribution",
    "configMap",
    "telemetry",
    "rag",
    "mcp",
    "mcp_aihub",
    "otelCollector",
    "guardrails"
  ],
  "additionalProperties": false
}
